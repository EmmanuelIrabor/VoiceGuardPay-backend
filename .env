# Copy this file to `.env` and fill in real values. Never commit the real .env.

# Neon Postgres — pooled connection string (hostname contains "-pooler")
# Neon dashboard -> your project -> Connection Details -> Pooled connection
APP_DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Neon Postgres — direct connection string (used only for Alembic migrations)
DATABASE_URL_DIRECT=postgresql+asyncpg://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=replace-this-with-a-generated-secret

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Your Next.js frontend's deployed URL (and localhost for dev)
FRONTEND_ORIGIN=http://localhost:3000
